# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Configurações de E-mail (SMTP) para envio automático de PDFs e EPUBs
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Supabase: usado no servidor para persistência da nuvem de projetos
SUPABASE_URL="MY_SUPABASE_URL"
SUPABASE_SERVICE_ROLE_KEY="MY_SUPABASE_SERVICE_ROLE_KEY"
SUPABASE_ANON_KEY="MY_SUPABASE_ANON_KEY"

# Variáveis expostas ao cliente Vite para autenticação Supabase
VITE_SUPABASE_URL="MY_SUPABASE_URL"
VITE_SUPABASE_ANON_KEY="MY_SUPABASE_ANON_KEY"
VITE_APP_URL="MY_APP_URL"

# Opcional: URL base de uma API externa quando o frontend for publicado sem o backend Express no mesmo host
# Exemplo: "https://meu-backend.exemplo.com"
VITE_SERVER_API_BASE_URL=""

# Opcional: habilita o fluxo de sincronização em nuvem no cliente fora do localhost
VITE_ENABLE_CLOUD_SYNC="false"
